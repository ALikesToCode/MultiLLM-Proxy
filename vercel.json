{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "version": 2,
    "builds": [
        {
            "src": "index.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "50mb"
            }
        },
        {
            "src": "static/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/static/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/index.py"
        }
    ],
    "env": {
        "PYTHONPATH": ".",
        "FLASK_ENV": "production",
        "FLASK_APP": "app.py"
    },
    "functions": {
        "index.py": {
            "maxDuration": 300,
            "excludeFiles": "{tests/**,__pycache__/**,.pytest_cache/**,.mypy_cache/**,.ruff_cache/**,.git/**,.venv/**,venv/**,node_modules/**,.wrangler/**,docs/**,instance/**,*.sqlite,*.sqlite3,*.db}"
        }
    }
}
